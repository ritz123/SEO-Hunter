# SEO Hunter — environment configuration
# Copy this file to .env and adjust values as needed.
# No API keys are required — the tool works fully with free, open services.

# ── Optional API Keys ─────────────────────────────────────────────────────────

# Google PageSpeed Insights (optional)
# If set, the auditor adds a PageSpeed score (0-100) to each audit.
# If blank, the PSI check is skipped — all other audit signals still run.
# Get key: https://developers.google.com/speed/docs/insights/v5/get-started
# GOOGLE_PSI_API_KEY=

# Yelp Fusion (optional fallback for business discovery)
# https://www.yelp.com/developers
# YELP_API_KEY=

# ── Prospecting defaults ──────────────────────────────────────────────────────

TARGET_CITY=San Francisco
TARGET_STATE=CA
TARGET_VERTICALS=plumbers,dentists,auto repair,HVAC,chiropractors
MAX_RESULTS_PER_SOURCE=50

# ── Scoring thresholds ────────────────────────────────────────────────────────

PRIORITY_A_THRESHOLD=8
PRIORITY_B_THRESHOLD=5

# ── HTTP settings ─────────────────────────────────────────────────────────────

REQUEST_TIMEOUT=15
REQUEST_DELAY=1.5

# ── Storage ───────────────────────────────────────────────────────────────────

OUTPUT_DIR=output
DATABASE_URL=sqlite:///sitecp.db

# ── Web server ────────────────────────────────────────────────────────────────

WEB_HOST=0.0.0.0
WEB_PORT=8000
