# ── Map & Geocoding ───────────────────────────────────────────────────────────
# No API keys needed! Map uses Leaflet.js + OpenStreetMap (free).
# Geocoding uses Nominatim (free, OSM-based).
# Business discovery uses OSM Overpass API (free) as default.

# ── PageSpeed Insights (optional) ────────────────────────────────────────────
# If set, the auditor adds a PageSpeed score check (0-100).
# If blank, this check is skipped — all other 16 audit signals still work.
# Get key: https://developers.google.com/speed/docs/insights/v5/get-started
# GOOGLE_PSI_API_KEY=

# ── Apify (optional, recommended for better business coverage) ────────────────
# Apify's Google Maps Scraper gives richer data than OSM Overpass.
# If blank, the tool falls back to OSM Overpass → Yellow Pages scraper.
# Get token: https://console.apify.com/account/integrations
# APIFY_API_TOKEN=
APIFY_ACTOR_ID=compass/google-maps-scraper
APIFY_MAX_ITEMS=100

# ── Yelp (optional, secondary fallback) ──────────────────────────────────────
# https://www.yelp.com/developers
# YELP_API_KEY=

# ── Prospecting defaults ──────────────────────────────────────────────────────
TARGET_CITY=San Francisco
TARGET_STATE=CA
TARGET_VERTICALS=plumbers,dentists,auto repair,HVAC,chiropractors
MAX_RESULTS_PER_SOURCE=50

# ── Scoring thresholds ────────────────────────────────────────────────────────
PRIORITY_A_THRESHOLD=8
PRIORITY_B_THRESHOLD=5

# ── HTTP settings ─────────────────────────────────────────────────────────────
REQUEST_TIMEOUT=15
REQUEST_DELAY=1.5

# ── Storage ───────────────────────────────────────────────────────────────────
OUTPUT_DIR=output
DATABASE_URL=sqlite:///sitecp.db

# ── Web server ────────────────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8000
